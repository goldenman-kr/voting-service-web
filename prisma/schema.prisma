generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ElectionState {
  draft
  ready_for_review
  approved
  scheduled
  notice
  open
  paused
  closed
  tallying
  pending_confirmation
  confirmed
  published
  archived
  invalidated
}

enum ElectionType {
  representative_election
  yes_no_agenda
  multiple_choice_agenda
  opinion_collection
}

enum VotingMode {
  anonymous
  named
}

enum AuthenticationMethod {
  invite_link_only
  invite_link_with_identifier
  email_code
  sms_code
  kakao_message
  external_identity
  sso
  legal_strong_auth
}

enum CredentialStatus {
  active
  locked
  revoked
  expired
}

enum AuthStatus {
  not_started
  identifier_verified
  code_pending
  authenticated
  failed
}

enum InvitationStatus {
  pending
  sent
  failed
  opened
  expired
  revoked
}

enum AnonymousVotingPassStatus {
  issued
  used
  revoked
  expired
}

enum BallotSubmissionStatus {
  received
  failed
  uncertain
}

enum BallotAcceptanceStatus {
  accepted
  rejected_late
  rejected_invalid
  superseded
}

enum VoteAnswerType {
  option
  free_text
  abstain
}

enum QuestionType {
  single_choice
  multiple_choice
  yes_no
  free_text
}

enum RecordStatus {
  active
  disabled
  archived
}

enum ResultStatus {
  draft
  tallied
  discarded
}

enum ResultVersionStatus {
  confirmed
  published
  superseded
}

enum ResultVersionType {
  initial
  correction
  withdrawal
  invalidation_notice
}

enum ReportType {
  result_summary
  question_detail
  participation
  audit_summary
  admin_activity
  dispute
  invalidation_correction
}

enum ExportStatus {
  requested
  approved
  rejected
  ready
  downloaded
  expired
  failed
}

enum AuditEventType {
  election_created
  election_updated
  election_review_requested
  election_approved
  election_rejected
  election_opened
  election_paused
  election_resumed
  election_closed
  election_archived
  election_invalidated
  authentication_policy_updated
  voter_registry_imported
  voter_registry_confirmed
  invitation_sent
  invitation_resend_requested
  role_changed
  permission_changed
  result_tally_started
  result_tallied
  result_confirmed
  result_published
  correction_requested
  correction_approved
  report_export_requested
  report_export_downloaded
  log_viewed
  log_export_requested
  log_export_downloaded
  deletion_requested
  deletion_approved
  deletion_completed
  db_access_requested
  db_access_approved
}

enum SecurityEventType {
  login_success
  login_failed
  mfa_success
  mfa_failed
  step_up_success
  step_up_failed
  permission_denied
  suspicious_access
  account_locked
}

enum CredentialEventType {
  invite_token_verified
  invite_token_failed
  invite_opened
  identifier_check_success
  identifier_check_failed
  code_sent
  code_resent
  code_verified
  code_failed
  external_auth_success
  external_auth_failed
  sso_auth_success
  sso_auth_failed
  locked
  unlocked
}

enum SubmissionEventType {
  submission_started
  submission_accepted
  submission_failed
  submission_uncertain
  late_rejected
  superseded
}

enum PermissionRiskLevel {
  low
  medium
  high
  critical
}

enum UserStatus {
  active
  invited
  locked
  disabled
}

enum OrganizationStatus {
  active
  suspended
  archived
}

enum TenantStatus {
  active
  suspended
  archived
}

enum RoleScope {
  system
  organization
  election
}

enum RegistryStatus {
  draft
  imported
  validated
  confirmed
  locked
}

enum ImportStatus {
  uploaded
  validating
  validated
  failed
}

enum ValidationErrorType {
  missing_required
  duplicate
  invalid_format
  conflict
}

enum DisputeStatus {
  submitted
  under_review
  accepted
  rejected
  withdrawn
}

enum CorrectionStatus {
  requested
  approved
  rejected
  applied
}

enum IncidentStatus {
  open
  mitigated
  resolved
}

enum IncidentSeverity {
  low
  medium
  high
  critical
}

enum DeletionStatus {
  requested
  approved
  rejected
  running
  completed
  failed
}

enum DeliveryStatus {
  pending
  sent
  failed
  suppressed
}

enum NotificationChannel {
  app
  email
  sms
  kakao
}

enum DbAccessType {
  read
  export
  maintenance
  restore
}

model Tenant {
  id            String          @id @default(uuid()) @db.Uuid
  name          String
  status        TenantStatus    @default(active)
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  organizations Organization[]
  users         User[]
  auditEvents   AuditEvent[]
  securityEvents SecurityEvent[]

  @@map("tenants")
}

model Organization {
  id                            String                         @id @default(uuid()) @db.Uuid
  tenantId                      String                         @map("tenant_id") @db.Uuid
  name                          String
  status                        OrganizationStatus             @default(active)
  defaultTimezone               String                         @default("Asia/Seoul") @map("default_timezone")
  settings                      Json?
  createdAt                     DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant                        Tenant                         @relation(fields: [tenantId], references: [id])
  users                         User[]
  roles                         Role[]
  elections                     Election[]
  organizationAuthMethods       OrganizationAuthenticationMethod[]
  managedVoterRegistries        ManagedVoterRegistry[]
  auditEvents                   AuditEvent[]
  retentionPolicies             RetentionPolicy[]
  deletionRequests              DeletionRequest[]
  notificationSettings          NotificationSetting[]
  deliveryEvents                DeliveryEvent[]

  @@unique([tenantId, name])
  @@index([tenantId, status])
  @@map("organizations")
}

model User {
  id                         String                 @id @default(uuid()) @db.Uuid
  tenantId                   String                 @map("tenant_id") @db.Uuid
  organizationId             String?                @map("organization_id") @db.Uuid
  emailHash                  String                 @map("email_hash")
  emailEncrypted             String?                @map("email_encrypted") @db.Text
  nameEncrypted              String?                @map("name_encrypted") @db.Text
  passwordHash               String                 @map("password_hash")
  status                     UserStatus             @default(active)
  mfaRequired                Boolean                @default(true) @map("mfa_required")
  lastLoginAt                DateTime?              @map("last_login_at") @db.Timestamptz(6)
  createdAt                  DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant                     Tenant                 @relation(fields: [tenantId], references: [id])
  organization               Organization?          @relation(fields: [organizationId], references: [id])
  mfaMethods                 UserMfaMethod[]
  adminSessions              AdminSession[]
  adminStepUpGrants          AdminStepUpGrant[]
  userRoles                  UserRole[]
  grantedRolePermissions     RolePermission[]       @relation("RolePermissionGrantedBy")
  electionsCreated           Election[]             @relation("ElectionCreatedBy")
  electionStateRequests      ElectionStateHistory[] @relation("ElectionStateRequestedBy")
  electionStateApprovals     ElectionStateHistory[] @relation("ElectionStateApprovedBy")
  electionChanges            ElectionChangeHistory[] @relation("ElectionChangeChangedBy")
  resultsTallied             Result[]               @relation("ResultTalliedBy")
  resultVersionsConfirmed    ResultVersion[]        @relation("ResultVersionConfirmedBy")
  reportsGenerated           Report[]               @relation("ReportGeneratedBy")
  reportExportsRequested     ReportExport[]         @relation("ReportExportRequestedBy")
  reportExportsApproved      ReportExport[]         @relation("ReportExportApprovedBy")
  disputesSubmitted          Dispute[]              @relation("DisputeSubmittedBy")
  disputesHandled            Dispute[]              @relation("DisputeHandledBy")
  correctionRequests         CorrectionRequest[]    @relation("CorrectionRequestedBy")
  correctionApprovals        CorrectionRequest[]    @relation("CorrectionApprovedBy")
  invalidationRequests       InvalidationRecord[]   @relation("InvalidationRequestedBy")
  invalidationApprovals      InvalidationRecord[]   @relation("InvalidationApprovedBy")
  incidentsCreated           OperationIncident[]    @relation("IncidentCreatedBy")
  auditEvents                AuditEvent[]           @relation("AuditActor")
  dbAccessEvents             DbAccessEvent[]        @relation("DbAccessActor")
  deletionRequestsRequested  DeletionRequest[]      @relation("DeletionRequestedBy")
  deletionRequestsApproved   DeletionRequest[]      @relation("DeletionApprovedBy")

  @@unique([tenantId, emailHash])
  @@index([organizationId, status])
  @@map("users")
}

model UserMfaMethod {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  methodType     String       @map("method_type")
  secretEncrypted String?     @map("secret_encrypted") @db.Text
  status         RecordStatus @default(active)
  lastUsedAt     DateTime?    @map("last_used_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  user           User         @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@map("user_mfa_methods")
}

model AdminSession {
  id                 String              @id @default(uuid()) @db.Uuid
  userId             String              @map("user_id") @db.Uuid
  /// HMAC or securely hashed opaque admin session token.
  /// Never store raw session tokens, passwords, IP, or User-Agent here.
  sessionTokenHash   String              @unique @map("session_token_hash")
  issuedAt           DateTime            @default(now()) @map("issued_at") @db.Timestamptz(6)
  expiresAt          DateTime            @map("expires_at") @db.Timestamptz(6)
  revokedAt          DateTime?           @map("revoked_at") @db.Timestamptz(6)
  lastUsedAt         DateTime?           @map("last_used_at") @db.Timestamptz(6)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  user               User                @relation(fields: [userId], references: [id])
  stepUpGrants       AdminStepUpGrant[]

  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
  @@map("admin_sessions")
}

model AdminStepUpGrant {
  id                 String       @id @default(uuid()) @db.Uuid
  adminSessionId     String       @map("admin_session_id") @db.Uuid
  userId             String       @map("user_id") @db.Uuid
  /// HMAC or securely hashed opaque step-up token.
  /// Never store raw step-up tokens, passwords, IP, or User-Agent here.
  tokenHash          String       @unique @map("token_hash")
  permissionCodes    Json         @map("permission_codes")
  purpose            String?      @db.Text
  verifiedAt         DateTime     @map("verified_at") @db.Timestamptz(6)
  expiresAt          DateTime     @map("expires_at") @db.Timestamptz(6)
  revokedAt          DateTime?    @map("revoked_at") @db.Timestamptz(6)
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  adminSession       AdminSession @relation(fields: [adminSessionId], references: [id])
  user               User         @relation(fields: [userId], references: [id])

  @@index([adminSessionId, revokedAt, expiresAt])
  @@index([userId, expiresAt])
  @@map("admin_step_up_grants")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  organizationId  String?          @map("organization_id") @db.Uuid
  code            String
  name            String
  scope           RoleScope
  isSystemRole    Boolean          @default(false) @map("is_system_role")
  status          RecordStatus     @default(active)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  organization    Organization?    @relation(fields: [organizationId], references: [id])
  permissions     RolePermission[]
  userRoles       UserRole[]

  @@unique([organizationId, code])
  @@index([scope])
  @@map("roles")
}

model Permission {
  id          String              @id @default(uuid()) @db.Uuid
  code        String              @unique
  description String
  riskLevel   PermissionRiskLevel @map("risk_level")
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String    @map("role_id") @db.Uuid
  permissionId String    @map("permission_id") @db.Uuid
  grantedById  String?   @map("granted_by") @db.Uuid
  grantedAt    DateTime  @default(now()) @map("granted_at") @db.Timestamptz(6)
  role         Role      @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])
  grantedBy    User?     @relation("RolePermissionGrantedBy", fields: [grantedById], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  roleId       String    @map("role_id") @db.Uuid
  electionId   String?   @map("election_id") @db.Uuid
  assignedAt   DateTime  @default(now()) @map("assigned_at") @db.Timestamptz(6)
  user         User      @relation(fields: [userId], references: [id])
  role         Role      @relation(fields: [roleId], references: [id])
  election     Election? @relation(fields: [electionId], references: [id])

  @@unique([userId, roleId, electionId])
  @@index([roleId])
  @@map("user_roles")
}

model Election {
  id                     String                    @id @default(uuid()) @db.Uuid
  organizationId         String                    @map("organization_id") @db.Uuid
  createdById            String?                   @map("created_by") @db.Uuid
  title                  String
  description            String?                   @db.Text
  electionType           ElectionType              @map("election_type")
  votingMode             VotingMode                @default(anonymous) @map("voting_mode")
  state                  ElectionState             @default(draft)
  noticeStartsAt         DateTime?                 @map("notice_starts_at") @db.Timestamptz(6)
  startsAt               DateTime                  @map("starts_at") @db.Timestamptz(6)
  endsAt                 DateTime                  @map("ends_at") @db.Timestamptz(6)
  timezone               String                    @default("Asia/Seoul")
  createdAt              DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization           Organization              @relation(fields: [organizationId], references: [id])
  createdBy              User?                     @relation("ElectionCreatedBy", fields: [createdById], references: [id])
  policy                 ElectionPolicy?
  authenticationPolicy   AuthenticationPolicy?
  stateHistories         ElectionStateHistory[]
  changeHistories        ElectionChangeHistory[]
  questions              Question[]
  voterRegistry          VoterRegistry?
  eligibleVoters         EligibleVoter[]
  invitations            Invitation[]
  votingCredentials      VotingCredential[]
  voterSessions          VoterSession[]
  credentialEvents       CredentialEvent[]
  anonymousVotingPasses  AnonymousVotingPass[]
  anonymousBallotGroups  AnonymousBallotGroup[]
  ballots                Ballot[]
  submissionEvents       SubmissionEvent[]
  results                Result[]
  resultVersions         ResultVersion[]
  reports                Report[]
  disputes               Dispute[]
  correctionRequests     CorrectionRequest[]
  invalidationRecords    InvalidationRecord[]
  incidents              OperationIncident[]
  deletionRequests       DeletionRequest[]
  deliveryEvents         DeliveryEvent[]
  userRoles              UserRole[]

  @@index([organizationId, state])
  @@index([startsAt, endsAt])
  @@map("elections")
}

model ElectionPolicy {
  id                         String   @id @default(uuid()) @db.Uuid
  electionId                 String   @unique @map("election_id") @db.Uuid
  allowRevote                Boolean  @default(true) @map("allow_revote")
  publishCounts              Boolean  @default(false) @map("publish_counts")
  resultAudience             String   @default("voters") @map("result_audience")
  requireResultConfirmation  Boolean  @default(true) @map("require_result_confirmation")
  smallElectionMinVoters     Int      @default(10) @map("small_election_min_voters")
  smallOptionMinVotes        Int      @default(3) @map("small_option_min_votes")
  createdAt                  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  election                   Election @relation(fields: [electionId], references: [id])

  @@map("election_policies")
}

model AuthenticationPolicy {
  id                   String               @id @default(uuid()) @db.Uuid
  electionId           String               @unique @map("election_id") @db.Uuid
  method               AuthenticationMethod @default(invite_link_with_identifier)
  isEnabled            Boolean              @default(true) @map("is_enabled")
  isPaidMethod         Boolean              @default(false) @map("is_paid_method")
  provider             String?
  securityLevel        String               @default("standard") @map("security_level")
  identifierFields     Json?                @map("identifier_fields")
  codeChannel          String?              @map("code_channel")
  codeTtlMinutes       Int?                 @map("code_ttl_minutes")
  maxCodeResends       Int?                 @map("max_code_resends")
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  election             Election             @relation(fields: [electionId], references: [id])

  @@index([method])
  @@map("authentication_policies")
}

model OrganizationAuthenticationMethod {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  method         AuthenticationMethod
  isAllowed      Boolean              @default(true) @map("is_allowed")
  isPaidMethod   Boolean              @default(false) @map("is_paid_method")
  provider       String?
  enabledAt      DateTime?            @map("enabled_at") @db.Timestamptz(6)
  disabledAt     DateTime?            @map("disabled_at") @db.Timestamptz(6)
  organization   Organization         @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, method, provider])
  @@map("organization_authentication_methods")
}

model ElectionStateHistory {
  id            String        @id @default(uuid()) @db.Uuid
  electionId    String        @map("election_id") @db.Uuid
  fromState     ElectionState? @map("from_state")
  toState       ElectionState @map("to_state")
  requestedById String?       @map("requested_by") @db.Uuid
  approvedById  String?       @map("approved_by") @db.Uuid
  reason        String?       @db.Text
  changeType    String        @map("change_type")
  changedAt     DateTime      @default(now()) @map("changed_at") @db.Timestamptz(6)
  election      Election      @relation(fields: [electionId], references: [id])
  requestedBy   User?         @relation("ElectionStateRequestedBy", fields: [requestedById], references: [id])
  approvedBy    User?         @relation("ElectionStateApprovedBy", fields: [approvedById], references: [id])

  @@index([electionId, changedAt])
  @@index([toState])
  @@map("election_state_histories")
}

model ElectionChangeHistory {
  id            String   @id @default(uuid()) @db.Uuid
  electionId    String   @map("election_id") @db.Uuid
  changedArea   String   @map("changed_area")
  beforeSummary Json?    @map("before_summary")
  afterSummary  Json?    @map("after_summary")
  changedById   String   @map("changed_by") @db.Uuid
  changedAt     DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)
  election      Election @relation(fields: [electionId], references: [id])
  changedBy     User     @relation("ElectionChangeChangedBy", fields: [changedById], references: [id])

  @@index([electionId, changedAt])
  @@map("election_change_histories")
}

model Question {
  id           String       @id @default(uuid()) @db.Uuid
  electionId   String       @map("election_id") @db.Uuid
  title        String
  description  String?      @db.Text
  questionType QuestionType @map("question_type")
  required     Boolean      @default(true)
  minSelect    Int?         @map("min_select")
  maxSelect    Int?         @map("max_select")
  displayOrder Int          @map("display_order")
  status       RecordStatus @default(active)
  election     Election     @relation(fields: [electionId], references: [id])
  options      Option[]
  votes        Vote[]
  resultItems  ResultItem[]

  @@unique([electionId, displayOrder])
  @@index([electionId])
  @@map("questions")
}

model Option {
  id           String       @id @default(uuid()) @db.Uuid
  questionId   String       @map("question_id") @db.Uuid
  label        String
  description  String?      @db.Text
  displayOrder Int          @map("display_order")
  status       RecordStatus @default(active)
  question     Question     @relation(fields: [questionId], references: [id])
  voteOptions  VoteOption[]
  resultItems  ResultItem[]

  @@unique([questionId, displayOrder])
  @@index([questionId])
  @@map("options")
}

model VoterRegistry {
  id                String                @id @default(uuid()) @db.Uuid
  electionId        String                @unique @map("election_id") @db.Uuid
  managedRegistryId String?               @map("managed_registry_id") @db.Uuid
  status            RegistryStatus        @default(draft)
  sourceType        String                @map("source_type")
  totalRows         Int                   @default(0) @map("total_rows")
  validRows         Int                   @default(0) @map("valid_rows")
  confirmedAt       DateTime?             @map("confirmed_at") @db.Timestamptz(6)
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  election          Election              @relation(fields: [electionId], references: [id])
  managedRegistry   ManagedVoterRegistry? @relation(fields: [managedRegistryId], references: [id])
  imports           VoterRegistryImport[]
  eligibleVoters    EligibleVoter[]

  @@index([managedRegistryId])
  @@map("voter_registries")
}

model ManagedVoterRegistry {
  id                 String          @id @default(uuid()) @db.Uuid
  organizationId     String          @map("organization_id") @db.Uuid
  title              String
  description        String?         @db.Text
  status             RegistryStatus  @default(validated)
  sourceType         String          @default("manual") @map("source_type")
  totalRows          Int             @default(0) @map("total_rows")
  validRows          Int             @default(0) @map("valid_rows")
  lockedAt           DateTime?       @map("locked_at") @db.Timestamptz(6)
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization       Organization    @relation(fields: [organizationId], references: [id])
  voters             ManagedVoter[]
  electionRegistries VoterRegistry[]

  @@index([organizationId, status])
  @@index([updatedAt])
  @@map("managed_voter_registries")
}

model ManagedVoter {
  id                          String               @id @default(uuid()) @db.Uuid
  managedRegistryId           String               @map("managed_registry_id") @db.Uuid
  nameEncrypted               String?              @map("name_encrypted") @db.Text
  phoneEncrypted              String?              @map("phone_encrypted") @db.Text
  externalIdentifierEncrypted String?              @map("external_identifier_encrypted") @db.Text
  externalIdentifierHmac      String               @map("external_identifier_hmac")
  status                      RecordStatus         @default(active)
  createdAt                   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  registry                    ManagedVoterRegistry @relation(fields: [managedRegistryId], references: [id])

  @@unique([managedRegistryId, externalIdentifierHmac])
  @@index([managedRegistryId, status])
  @@map("managed_voters")
}

model VoterRegistryImport {
  id                     String                         @id @default(uuid()) @db.Uuid
  voterRegistryId         String                         @map("voter_registry_id") @db.Uuid
  importStatus            ImportStatus                   @default(uploaded) @map("import_status")
  fileName                String?                        @map("file_name")
  fileHash                String?                        @map("file_hash")
  rowCount                Int                            @default(0) @map("row_count")
  uploadedAt              DateTime                       @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  registry                VoterRegistry                  @relation(fields: [voterRegistryId], references: [id])
  validationErrors        VoterRegistryValidationError[]

  @@index([voterRegistryId, importStatus])
  @@map("voter_registry_imports")
}

model VoterRegistryValidationError {
