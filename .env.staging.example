# Self-hosted staging example only. Copy to .env.staging on the server.
# Never commit .env.staging or real secret values.

NODE_ENV="production"
APP_URL="https://staging.example.com"

# Docker Compose staging default points at the postgres service on the private Docker network.
# Replace CHANGE_ME values on the server only.
POSTGRES_DB="voting_service_web_staging"
POSTGRES_USER="voting_app"
POSTGRES_PASSWORD="CHANGE_ME_STAGING_POSTGRES_PASSWORD"
DATABASE_URL="postgresql://voting_app:CHANGE_ME_STAGING_POSTGRES_PASSWORD@postgres:5432/voting_service_web_staging?schema=public"

# Generate separate staging-only random values. Do not reuse local, CI, or production secrets.
SESSION_SECRET="CHANGE_ME_32_BYTES_OR_MORE_RANDOM"
ENCRYPTION_KEY="CHANGE_ME_32_BYTES_OR_MORE_RANDOM"
HMAC_KEY="CHANGE_ME_32_BYTES_OR_MORE_RANDOM"

# Host-local app port for the reverse proxy upstream.
APP_HOST_PORT="3000"

# Bootstrap-only values. Remove from .env.staging after first admin bootstrap.
BOOTSTRAP_ADMIN_EMAIL="staging-admin@example.com"
BOOTSTRAP_ADMIN_PASSWORD="CHANGE_ME_TEMPORARY_BOOTSTRAP_PASSWORD"
BOOTSTRAP_TENANT_NAME="Staging Tenant"
BOOTSTRAP_ORGANIZATION_NAME="Staging Organization"
BOOTSTRAP_ADMIN_ROLE="OrganizationOwner"
BOOTSTRAP_CONFIRM="CREATE_INITIAL_ADMIN"

# Future/disabled provider placeholders.
# EMAIL_PROVIDER_API_KEY=""
# SMS_PROVIDER_API_KEY=""
# KAKAO_PROVIDER_API_KEY=""
# EXTERNAL_IDENTITY_PROVIDER_CLIENT_ID=""
# SSO_PROVIDER_CLIENT_ID=""
# KMS_KEY_ID=""
# APM_DSN=""
