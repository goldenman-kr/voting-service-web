#!/usr/bin/env bash
set -euo pipefail

# Self-hosted staging PostgreSQL backup example.
# Copy to a server-local script path before use, review it, chmod 700, and keep real secrets out of git.
#
# Default mode backs up the Compose PostgreSQL service without exposing PostgreSQL on a host port.
# It passes the staging env file only to Docker Compose and does not print env values.
#
# Optional env:
#   BACKUP_METHOD - compose or url, default compose
#   STAGING_ENV_FILE - compose env file, default .env.staging
#   COMPOSE_FILE - compose file, default docker-compose.staging.yml
#   COMPOSE_SERVICE - PostgreSQL service name, default postgres
#   DATABASE_URL - required only when BACKUP_METHOD=url
#   BACKUP_DIR - output directory, default /mnt/data_4tb/voting-service-web/backups
#   BACKUP_PREFIX - filename prefix, default voting-service-web-staging
#   AGE_RECIPIENT - optional age recipient for encryption, if age is installed
#   OFFSITE_DIR - optional mounted offsite/NAS directory for rsync copy
#   OFFSITE_DRY_RUN - yes/no, default yes

if [[ "${NODE_ENV:-}" == "production" && "${ALLOW_STAGING_BACKUP_IN_PRODUCTION_NODE_ENV:-}" != "yes" ]]; then
  echo "Refusing to run with NODE_ENV=production unless ALLOW_STAGING_BACKUP_IN_PRODUCTION_NODE_ENV=yes is set." >&2
  echo "This script is for staging only. Confirm the target database before proceeding." >&2
  exit 1
fi

BACKUP_METHOD="${BACKUP_METHOD:-compose}"
STAGING_ENV_FILE="${STAGING_ENV_FILE:-.env.staging}"
COMPOSE_FILE="${COMPOSE_FILE:-docker-compose.staging.yml}"
COMPOSE_SERVICE="${COMPOSE_SERVICE:-postgres}"

if [[ "${BACKUP_METHOD}" != "compose" && "${BACKUP_METHOD}" != "url" ]]; then
  echo "BACKUP_METHOD must be compose or url." >&2
  exit 1
fi

if [[ "${BACKUP_METHOD}" == "url" ]]; then
  if [[ -z "${DATABASE_URL:-}" ]]; then
    echo "DATABASE_URL is required for BACKUP_METHOD=url and must point to staging." >&2
    exit 1
  fi

  if [[ "${DATABASE_URL}" == *"prod"* || "${DATABASE_URL}" == *"production"* ]]; then
    echo "Refusing to run because DATABASE_URL looks production-like." >&2
    exit 1
  fi
else
  if [[ ! -f "${STAGING_ENV_FILE}" ]]; then
    echo "STAGING_ENV_FILE was not found. Refusing to continue." >&2
    exit 1
  fi
fi

BACKUP_DIR="${BACKUP_DIR:-/mnt/data_4tb/voting-service-web/backups}"
BACKUP_PREFIX="${BACKUP_PREFIX:-voting-service-web-staging}"
TIMESTAMP="$(date -u +"%Y%m%dT%H%M%SZ")"
OUT_BASE="${BACKUP_DIR}/${BACKUP_PREFIX}-${TIMESTAMP}"
DUMP_FILE="${OUT_BASE}.dump"
GZIP_FILE="${DUMP_FILE}.gz"

mkdir -p "${BACKUP_DIR}"
chmod 700 "${BACKUP_DIR}"

echo "Creating PostgreSQL custom-format dump at ${DUMP_FILE}"
if [[ "${BACKUP_METHOD}" == "url" ]]; then
  pg_dump "${DATABASE_URL}" --format=custom --file "${DUMP_FILE}"
else
  docker compose --env-file "${STAGING_ENV_FILE}" -f "${COMPOSE_FILE}" exec -T "${COMPOSE_SERVICE}" \
    sh -lc 'pg_dump -U "$POSTGRES_USER" -d "$POSTGRES_DB" --format=custom' >"${DUMP_FILE}"
fi
chmod 600 "${DUMP_FILE}"

echo "Compressing backup to ${GZIP_FILE}"
gzip -9 "${DUMP_FILE}"
chmod 600 "${GZIP_FILE}"

FINAL_FILE="${GZIP_FILE}"

if [[ -n "${AGE_RECIPIENT:-}" ]]; then
  if ! command -v age >/dev/null 2>&1; then
    echo "AGE_RECIPIENT is set but age is not installed." >&2
    exit 1
  fi

  echo "Encrypting backup with age"
  age -r "${AGE_RECIPIENT}" -o "${GZIP_FILE}.age" "${GZIP_FILE}"
  chmod 600 "${GZIP_FILE}.age"
  rm -f "${GZIP_FILE}"
  FINAL_FILE="${GZIP_FILE}.age"
  echo "Encrypted backup written to ${GZIP_FILE}.age"
else
  echo "Unencrypted compressed backup written to ${GZIP_FILE}"
  echo "Move it to encrypted/offsite storage if beta data matters."
fi

if [[ -n "${OFFSITE_DIR:-}" ]]; then
  if ! command -v rsync >/dev/null 2>&1; then
    echo "OFFSITE_DIR is set but rsync is not installed." >&2
    exit 1
  fi

  mkdir -p "${OFFSITE_DIR}"
  if [[ "${OFFSITE_DRY_RUN:-yes}" == "yes" ]]; then
    echo "Dry-run offsite copy to ${OFFSITE_DIR}"
    rsync --archive --dry-run "${FINAL_FILE}" "${OFFSITE_DIR}/"
  else
    echo "Copying backup to offsite directory ${OFFSITE_DIR}"
    rsync --archive "${FINAL_FILE}" "${OFFSITE_DIR}/"
  fi
fi

echo "Backup complete. Rehearse restore into a non-production database before relying on this backup."
