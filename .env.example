# Local development placeholder values only. Do not use these values in production.
DATABASE_URL="postgresql://voting_app:voting_app_dev_password_only@localhost:5432/voting_service_web?schema=public"
APP_URL="http://localhost:3000"
SESSION_SECRET="dev-only-session-secret-change-before-production"
ENCRYPTION_KEY="dev-only-encryption-key-change-before-production"
HMAC_KEY="dev-only-hmac-key-change-before-production"

# Optional one-time initial admin bootstrap placeholders.
# Do not commit real administrator credentials.
BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
BOOTSTRAP_ADMIN_PASSWORD="replace-with-a-one-time-password-at-least-12-chars"
BOOTSTRAP_TENANT_NAME="Development Tenant"
BOOTSTRAP_ORGANIZATION_NAME="Development Organization"
BOOTSTRAP_ADMIN_ROLE="OrganizationOwner"
# Required only when NODE_ENV=production.
BOOTSTRAP_CONFIRM=""

# Optional local-only E2E cleanup controls.
# Leave empty unless manually deleting E2E fixture data from the local development DB.
E2E_CLEANUP_CONFIRM=""
E2E_CLEANUP_RUN_ID=""
